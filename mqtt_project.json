    {
        "id": "svg_update",
        "type": "ui_template",
        "z": "56a075eed90b9475",
        "group": "home_group",
        "name": "SVG UPDATE LOGIC",
        "order": 6,
        "width": 0,
        "height": 0,
        "format": "<script>\n(function(scope) {\n  scope.$watch('msg', function(msg) {\n    if (!msg) return;\n\n    // LIGHT\n    if (msg.topic === \"home/living/light\") {\n      document.getElementById(\"light-living\").style.fillOpacity = (msg.payload === \"ON\") ? 0.18 : 0;\n    }\n\n    // TV\n    if (msg.topic === \"home/tv\") {\n      document.getElementById(\"tv-playing\").style.opacity = (msg.payload === \"ON\") ? 1 : 0;\n    }\n\n    // AC\n    if (msg.topic === \"home/ac/living\") {\n      document.getElementById(\"ac-living\").style.opacity = (msg.payload === \"ON\") ? 1 : 0;\n    }\n\n    // HEAT\n    if (msg.topic === \"home/heat/living\") {\n      document.getElementById(\"heat-living\").style.opacity = (msg.payload === \"ON\") ? 1 : 0;\n    }\n\n    // FRIDGE TEMP\n    if (msg.topic === \"home/fridge/temp\") {\n      document.getElementById(\"fridge-temp\").textContent = msg.payload + \"°C\";\n\n      if (msg.payload > 8) {\n        document.getElementById(\"fridge-warn\").style.opacity = 1;\n      } else {\n        document.getElementById(\"fridge-warn\").style.opacity = 0;\n      }\n    }\n\n  });\n})(scope);\n</script>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": false,
